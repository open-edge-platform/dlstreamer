+typedef struct _GstAnalyticsMtd GstAnalyticsGroupMtd;
+
+
+GST_ANALYTICS_META_API
+GstAnalyticsMtdType gst_analytics_group_mtd_get_mtd_type (void);
+
+GST_ANALYTICS_META_API
