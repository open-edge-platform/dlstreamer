    ],
    "lab_cam1_main": [
      "gst-launch-1.0",
      "-v",
      "rtspsrc",
      "location={rtsp_url}",
      "!",
      "rtph264depay",
      "!",
      "h264parse",
      "!",
      "avdec_h264",
      "!",
      "videoconvert",
      "!",
      "gvawatermark",
      "displ-cfg=ff-custom-txt=FROM_JSON_FILE,text-x=50,text-y=50,font-scale=1.0,color-idx=1",
      "!",
      "ximagesink"
    ],
    "move_detected_ball_test": [
      "gst-launch-1.0",
      "-v",
      "videotestsrc",
      "pattern=ball",
      "!",
      "videoconvert",
      "!",
      "gvawatermark",
      "displ-cfg=ff-custom-txt='Move detected',text-x=50,text-y=50,font-scale=1.0,color-idx=1",
      "!",
      "videoconvert",
      "!",
      "autovideosink"
    ],
