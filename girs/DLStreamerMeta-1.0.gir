    <function name="relation_meta_get_zone_mtd" c:identifier="gst_analytics_relation_meta_get_zone_mtd">
      <doc xml:space="preserve" filename="include/dlstreamer/gst/metadata/gva_zone_meta.h" line="56">Retrieves zone metadata by its ID from the analytics relation metadata.</doc>
