      </return-value>
      <parameters>
        <parameter name="instance" transfer-ownership="none">
          <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="338">Instance of @GstAnalyticsRelationMeta where to add group_mtd
   instance</doc>
