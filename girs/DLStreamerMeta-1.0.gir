    <function name="relation_meta_add_group_mtd" c:identifier="gst_analytics_relation_meta_add_group_mtd" version="1.30">
      <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="296">Add mtd grouping metadata to @inscance. Use this API when the number of members
need to be dynamic, otherwise prefer
@gst_analytics_relation_meta_add_group_mtd_with_size.</doc>
      <source-position filename="include/dlstreamer/gst/metadata/gstanalyticsgroupmtd.h" line="70" />
      <return-value transfer-ownership="none">
        <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="308">TRUE is added successfully, otherwise FALSE.</doc>
        <type name="gboolean" c:type="gboolean" />
      </return-value>
      <parameters>
        <parameter name="instance" transfer-ownership="none">
          <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="298">Instance of @GstAnalyticsRelationMeta where to add group_mtd
   instance</doc>
          <type name="GstAnalytics.RelationMeta" c:type="GstAnalyticsRelationMeta*" />
        </parameter>
        <parameter name="pre_alloc_size" transfer-ownership="none">
          <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="300">Slots allocated for group members</doc>
          <type name="gsize" c:type="gsize" />
        </parameter>
        <parameter name="group_mtd" direction="out" caller-allocates="1" transfer-ownership="none">
          <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="301">Handle to updated to newly added grouping
   mtd</doc>
          <type name="GroupMtd" c:type="GstAnalyticsGroupMtd*" />
        </parameter>
      </parameters>
    </function>
    <function name="relation_meta_add_group_mtd_with_size" c:identifier="gst_analytics_relation_meta_add_group_mtd_with_size" version="1.30">
      <doc xml:space="preserve" filename="src/gst/metadata/gstanalyticsgroupmtd.c" line="336">Add mtd grouping metadata to @inscance. Use this API when the number of
